{
  "name": "omnibazaar-mobile",
  "version": "0.1.0",
  "description": "Native iOS and Android applications for OmniBazaar decentralized marketplace",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "sync:i18n": "node scripts/sync-i18n.mjs",
    "audit:i18n": "node scripts/audit-i18n.mjs",
    "e2e:build:ios": "detox build --configuration ios",
    "e2e:build:android": "detox build --configuration android",
    "e2e:test:ios": "detox test --configuration ios",
    "e2e:test:android": "detox test --configuration android",
    "e2e:maestro": "maestro test .maestro/",
    "e2e:maestro:ci": "maestro test --format junit --output maestro-report.xml .maestro/",
    "build:preview": "./scripts/eas-preview.sh",
    "build:preview:ios": "./scripts/eas-preview.sh ios",
    "build:preview:android": "./scripts/eas-preview.sh android",
    "build:preview:apk": "./scripts/eas-preview.sh apk",
    "ota:preview": "./scripts/ota.sh preview",
    "ota:production": "./scripts/ota.sh production",
    "postinstall": "patch-package",
    "clean": "rm -rf node_modules ios/build android/build",
    "clean:all": "npm run clean && rm -rf ios/Pods .expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@ledgerhq/react-native-hid": "^6.39.1",
    "@react-native-async-storage/async-storage": "~1.21.0",
    "@react-native-community/netinfo": "11.1.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^2.0.1",
    "@sentry/react-native": "~5.30.0",
    "@shopify/flash-list": "~1.6.4",
    "@shopify/react-native-skia": "0.1.221",
    "@tanstack/react-query": "^5.17.0",
    "buffer": "^6.0.3",
    "ethers": "^6.16.0",
    "expo": "~50.0.0",
    "expo-barcode-scanner": "~12.9.0",
    "expo-build-properties": "^0.11.1",
    "expo-camera": "~14.0.0",
    "expo-clipboard": "~5.0.0",
    "expo-constants": "~15.4.0",
    "expo-crypto": "~12.8.0",
    "expo-device": "~5.9.0",
    "expo-file-system": "~16.0.0",
    "expo-haptics": "~12.8.0",
    "expo-image": "~1.10.0",
    "expo-image-picker": "~14.7.0",
    "expo-linking": "~6.2.0",
    "expo-local-authentication": "~13.8.0",
    "expo-localization": "~14.8.0",
    "expo-location": "~16.5.0",
    "expo-notifications": "~0.27.0",
    "expo-screen-capture": "~5.8.0",
    "expo-secure-store": "~12.8.0",
    "expo-sharing": "~11.10.0",
    "expo-splash-screen": "~0.26.0",
    "expo-status-bar": "~1.11.0",
    "expo-updates": "~0.24.0",
    "expo-web-browser": "~12.8.2",
    "fast-text-encoding": "^1.0.6",
    "i18next": "^23.7.16",
    "lottie-react-native": "6.5.1",
    "process": "^0.11.10",
    "react": "18.2.0",
    "react-i18next": "^14.0.0",
    "react-native": "0.73.2",
    "react-native-ble-plx": "^3.1.2",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-get-random-values": "~1.8.0",
    "react-native-mmkv": "^2.11.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~3.6.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-webview": "13.6.4",
    "react-redux": "^9.0.4",
    "redux-persist": "^6.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/react-native": "^12.4.2",
    "@types/jest": "^29.5.11",
    "@types/react": "~18.2.45",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "detox": "^20.14.8",
    "eslint": "^8.56.0",
    "eslint-config-expo": "^7.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-expo": "^0.0.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~50.0.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.1.1",
    "react-native-dotenv": "^3.4.9",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.3.0"
  },
  "_jest_comment": "Jest config now lives in jest.config.js (see that file).",
  "private": true,
  "engines": {
    "node": ">=22.18.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/omnibazaar/mobile.git"
  },
  "keywords": [
    "omnibazaar",
    "marketplace",
    "wallet",
    "dex",
    "blockchain",
    "react-native",
    "expo",
    "mobile"
  ],
  "author": "OmniBazaar Team",
  "license": "MIT"
}
