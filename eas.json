{
  "cli": {
    "version": ">= 11.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.18.0",
      "env": {
        "EXPO_PUBLIC_VALIDATOR_ENDPOINT": "http://65.108.205.116:3001"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium",
        "simulator": true
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_PUBLIC_MAESTRO_SKIP_VERIFY": "true",
        "EXPO_PUBLIC_MAESTRO_DEFAULT_PIN": "123456"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_BUILD_CHANNEL": "preview",
        "EXPO_PUBLIC_SENTRY_DSN": "${SENTRY_DSN}"
      }
    },
    "production-apk": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      },
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_BUILD_CHANNEL": "production",
        "EXPO_PUBLIC_SENTRY_DSN": "${SENTRY_DSN}"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "medium"
      },
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_BUILD_CHANNEL": "production",
        "EXPO_PUBLIC_SENTRY_DSN": "${SENTRY_DSN}"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "${APPLE_ID}",
        "ascAppId": "${ASC_APP_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}"
      },
      "android": {
        "serviceAccountKeyPath": "./secrets/google-play-key.json",
        "track": "internal",
        "changesNotSentForReview": false
      }
    }
  }
}
